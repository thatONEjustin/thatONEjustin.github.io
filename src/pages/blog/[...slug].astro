---
/*
 * NOTE: the cool thing I'm seeing here is that
 * with astro its pretty easy to go between SSG
 * and SSR.
 *  
 * For now I'm going to stay with a build based 
 * deployment, I have a workflow with it and 
 * I want to keep that energy up.
 */
export const prerender = true

import { getCollection } from 'astro:content';
import { marked } from 'marked';

import { blogDate } from '@js/helpers'
import BaseLayout from "@layouts/base.astro"

export async function getStaticPaths() {
    const blog_data = await getCollection('blog');

    // console.log(blog_data)
    const paths = blog_data.map(({...post}: any) => {
        // console.log(post.data.slug)
        if (post == null) return {}
        return {
            params: { slug: post.data.slug },
            props:{...post.data} 
        }
    })

    return paths
}

const { title, publishedAt, content } = Astro.props
---
<BaseLayout>
    <article class="min-h-screen relative" itemscope itemtype="https://schema.org/BlogPosting">
        <section class="blog-post-title">
            <div class="container mx-auto relative z-50">
                <h2 class="text-7xl text-purple text-left" itemprop="headline">{title}</h2>
                <div class="flex mx-auto w-fit text-left">
                    <h6 itemprop="author" itemscope itemtype="https://schema.org/Person" class="text-purple-300 mr-2"><em>written by</em> <span class="text-cyan" itemprop="givenName">Justin</span> <span class="text-cyan" itemprop="familyName">Paelmo</span></h6>
                    <h6 class="text-purple-300/50" itemprop="datePublished"><em>published {blogDate(publishedAt)}</em></h6>
                </div>
            </div>
        </section>
        <section class="markdown-content overflow-hidden pt-8 z-10">
            <div class="justin-container mx-auto" itemprop="articleBody">
                <Fragment set:html={marked.parse(content)} />
            </div>
        </section>
    </article>
</BaseLayout>

<style>
@reference '@css/main.css';

.blog-post-title {
    @apply px-8 py-6 grid-bg sticky top-15 z-40 shadow-2xl;

    &:before {
        @apply opacity-85;
    }

    @variant lg {
        @apply top-0;
    }
}
</style>
