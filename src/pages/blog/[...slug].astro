---
<BaseLayout>
    <section class="bg-darker-900">
        <div class="container mx-auto">
            <h1>{Title}</h1>
            <h6 class="text-darker-50 opacity-30 text-xs"><em>published: {blogDate(publishedAt)}</em></h6>
            {Content}
        </div>
    </section>
</BaseLayout>
