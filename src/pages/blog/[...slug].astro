/*
 * FIXED: SSG was causing problems but I'm going to assume its two things:
 * 1. moving to the astro patterns for their fetch() implementation/real world
 * 2. the server is awake and not causing problems
 */
export const prerender = true

import { marked } from 'marked';
import { getData, blogDate } from '@js/helpers'
import BaseLayout from "@layouts/base.astro"

export async function getStaticPaths() {
    const data = await getData('blog-posts').then(r => r.json())

    const posts = data.data.map(({slug, Title, publishedAt, Content}: any) => {
        console.log(slug)
        return {
            params: { slug },

            props: { Title, publishedAt, Content },
        }
    })

    return posts
}

const { slug } = Astro.params
const { Title, publishedAt, Content } = Astro.props
---
<BaseLayout>
    <section class="bg-darker min-h-screen">
        <div class="container mx-auto">
            <h1>{Title}</h1>
            <h6 class="text-darker-50 opacity-30 text-xs"><em>published: {blogDate(publishedAt)}</em></h6>
            <Fragment set:html={await marked.parse(Content)} />
        </div>
    </section>
</BaseLayout>
