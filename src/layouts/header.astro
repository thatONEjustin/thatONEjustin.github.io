---
import Menu from "@components/menu/Menu.astro";
type MenuItem = {
  label: string,
  href: string,
  icon: string,
  scrollTo?: string
}

const menu_data: MenuItem[] = [
  {
    label: 'home',
    href: '#',
    icon: 'nf-custom-home',
    scrollTo: 'top'
  },
  {
    label: 'about',
    href: '#about-me',
    icon: 'nf-dev-terminal',
    scrollTo: 'about-me'
  },
  {
    label: 'skills',
    href: '#skills',
    icon: 'nf-md-keyboard',
    scrollTo: 'skills'
  },
  // {
  //   'label': 'blog',
  //   'href': '/blog',
  //   'icon': 'nf-md-pen'
  // },
]
---

<header class="xl:sticky xl:top-0 z-50">
    <div class="fancy-border bg-darker-900">
        <div class="container mx-auto w-11/12 md:w-full flex flex-col sm:flex-row justify-between items-center py-3">
            <a href="/" class="text-3xl flex items-baseline no-underline">
                <i class="text-3xl sm:text-4xl nf nf-dev-terminal text-pink mr-2"> </i>
                <h1>i'm justin a<div class="text-green">&nbsp;full stack <i class="text-2xl sm:text-3xl nf nf-oct-stack"></i>&nbsp;</div>developer</h1>
                <span class="sr-only">I'm Justin Paelmo, a full stack developer</span>
            </a>
            <Menu transition:persist items={menu_data} />
        </div>
    </div>
</header>

<style>
    @reference "../css/main.css";
    header {
        h1 {
            @apply relative items-start justify-center -mt-1 text-2xl;
            @apply text-yellow;
            @apply transition-all;

            @variant sm {
                @apply flex text-3xl flex-col;
            }

            @variant md {
                @apply text-4xl;
            }

            @variant lg {
                @apply flex-col;
            }

            @variant xl {
                @apply flex-row;
            }
        }
    }
</style>
