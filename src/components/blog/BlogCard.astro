---
import { blogDate } from '@js/helpers'
import { truncateWords } from '@shahid19/stringjs'
import { marked } from 'marked'

const { data } = Astro.props

const { slug, publishedAt, Content, Title } = data

async function preview(text: string, truncate:number = 0) {
    if(truncate >= 1 && truncate != null) {
        text = truncateWords(text, truncate)
    }

    const marked_down_text = await marked.parse(text)
    const cleaned_text = marked_down_text.replace(/<\/?[^>]+(>|$)/g, "")

    return cleaned_text
}
---

<article class="blog-post-card">
    <a href=`/blog/${slug}` class="no-underline">
        <h3 class="title" set:html={preview(Title, 7)}></h3>
        <h6 class="date"><em>published: {blogDate(publishedAt)}</em></h6>

        <p class="preview" set:html={preview(Content, 15)}></p>
        <span class="read-more">read more</span>
    </a>
</article>

<style>
@reference '@css/main.css';

.blog-post-card {
    @apply p-4 rounded border-darker-800 border;
    @apply bg-darker-50;

    .title {
        @apply w-full text-buffy-800 border-b border-b-darker-800 pb-2 mb-4
    }

    .date {
        @apply text-darker-400 text-xs;
    }

    .preview {
        @apply mb-4 text-darker-900;
    }
}
</style>

