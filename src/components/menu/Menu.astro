<script>

function clean_path (path:string) {
    if(path == '/') return path

    return path.replace(/\/$/, "")
}

function init () {
    const items = document.querySelectorAll(".menu-item");

    for(var button of items) {
        const button_path = new URL(button.href).pathname
        const window_path = window.location.pathname

        if(button_path == window_path) {
            button.classList.add('active')
        } else if(button_path != '/' && window_path != '/' && window_path.includes(button_path)) {
            button.classList.add('active')
        } else {
            button.classList.remove('active')
        }
    }
}

document.addEventListener("astro:page-load", init);

</script>
<ul class="flex flex-row items-start py-4 md:py-0">
    {menu.map((item: any) => 
        <MenuItem {item} />
    )}
  
    <!-- <li>
        <ToggleMode />
    </li> -->
</ul>
