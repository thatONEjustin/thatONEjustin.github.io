<script>

function clean_path(path:string) {
    if(path == '/') {
        return path
    }

    return path.replace(/\/$/, "")
}

function init() {
    let current_path = window.location.pathname
    if(current_path != '/') {
        current_path = clean_path(current_path)
    }
    console.log(`current_path: ${current_path}`)

    var items = document.querySelectorAll(".menu-item");

    for(var button of items) {
        let button_path = new URL(button.href)

        if(clean_path(button_path.pathname) == clean_path(window.location.pathname)) {
            button.classList.add('active')
        } else {
            button.classList.remove('active')
        }
    }
}
document.addEventListener("astro:page-load", init);

</script>
<ul class="flex flex-row items-start py-4 md:py-0">
    {menu.map((item: any) => 
        <MenuItem {item} />
    )}
  
    <!-- <li>
        <ToggleMode />
    </li> -->
</ul>
