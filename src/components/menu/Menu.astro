  label: string,
  href: string,
  icon: string,
  scrollTo?: string
}

const menu: MenuItem[] = [
    {
        label: 'home',
        href: '/',
        icon: 'nf-custom-home',
    },
    {
        label: 'about',
        href: '/about-me',
        icon: 'nf-oct-person_fill',
    },
    {
        label: 'portfolio',
        href: '/portfolio',
        icon: 'nf-dev-terminal'
    },
]
